<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.automation.apple-events</key>
    <false/>
    <!-- Self-signed certs have no Team ID, so dyld + hardened runtime would
         reject every dylib load (SPM frameworks, debug.dylib, __preview.dylib)
         with "different Team IDs". This entitlement tells the hardened runtime
         to skip the team-ID check on library loads. Standard pattern for
         self-signed dev builds. We'd remove this if we ever ship under a real
         Developer ID. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
