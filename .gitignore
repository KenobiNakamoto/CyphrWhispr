# Xcode
build/
# the iCloud .nosync symlink (build -> build.nosync); the rule above
# only matches a real directory, so the symlink needs its own line.
build
DerivedData/
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xcuserstate
*.xcuserdatad
*.xcuserdata
*.moved-aside

# LLVM coverage artefacts that XCTest drops in the working directory
# whenever a test run is invoked. Not useful to track and they keep
# reappearing if not ignored.
*.profraw
*.profdata

# Swift Package Manager
.swiftpm/
.build/
Package.resolved
Packages/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# CyphrWhispr local artefacts
models/
*.mlmodelc/
*.gguf
*.bin

# AI assistant scratch, working notes, and project memory (local-only).
# This repo is a public FOSS project. The operator's working context —
# AI instructions and the memory/ folder (which carries identity notes
# tied to the operator's real name) — is deliberately kept off GitHub.
.claude/
.superpowers/
CLAUDE.md
memory/

# User-only design source artefacts (mockup ZIPs, working files, decks).
# The canonical mockups that ship with the repo live under
# docs/superpowers/specs/assets/ — this folder is the import drop zone.
Visual Aides/
*.zip
CyphrWhispr BIP Deck.html

# iCloud-excluded dependency dirs
*.nosync
